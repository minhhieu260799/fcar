@startuml FCAR-quan-ly-don-hang-admin
' Ký hiệu theo mẫu giảng viên: swimlane, start/stop, nhánh [guard], fork/join, merge

skinparam backgroundColor white
skinparam activity {
  BackgroundColor white
  BorderColor black
  DiamondBackgroundColor white
  FontSize 11
}
skinparam ArrowColor black

title Activity Diagram — Quản lý đơn hàng phía Admin (FCAR)

|Quản trị viên|
start
:Mở danh sách đơn hàng;

|Hệ thống FCAR|
:Lọc/tải danh sách theo thời gian và trạng thái;
:Mở chi tiết đơn;

|Quản trị viên|
:Chọn thao tác trên đơn;

|Hệ thống FCAR|
if (Thao tác?) then ([Đánh dấu đã giao])
  if (Đơn đang DEPOSITED?) then ([Không])
    |Quản trị viên|
    :Hiển thị lỗi thao tác không hợp lệ;
    stop
  else ([Có])
    fork
      :Cập nhật trạng thái DELIVERED;
    fork again
      :Gửi email thông báo đã giao xe;
    end fork
  endif
else ([Hủy đơn])
  if (Đơn đang DEPOSITED?) then ([Không])
    |Quản trị viên|
    :Hiển thị lỗi thao tác không hợp lệ;
    stop
  else ([Có])
    fork
      :Cập nhật trạng thái CANCELED;
    fork again
      :Gửi email thông báo hủy đơn;
    end fork
  endif
endif

|Quản trị viên|
:Nếu cần, chọn xác nhận hoàn tiền;

|Hệ thống FCAR|
if (Xác nhận hoàn tiền?) then ([Có])
  if (Đơn đang CANCELED và có ảnh chứng từ?) then ([Không])
    |Quản trị viên|
    :Hiển thị lỗi thiếu điều kiện hoàn tiền;
    stop
  else ([Có])
    fork
      :Upload ảnh chứng từ + cập nhật REFUNDED;
    fork again
      :Cộng lại tồn kho xe (+1);
    fork again
      :Gửi email xác nhận hoàn tiền;
    end fork
  endif
else ([Không])
endif

|Quản trị viên|
:Xem chi tiết đơn đã cập nhật;
stop

@enduml
