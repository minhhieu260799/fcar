@startuml FCAR-dang-ky-tai-khoan
' Ký hiệu theo mẫu giảng viên: swimlane, start/stop, nhánh [guard], merge

skinparam backgroundColor white
skinparam activity {
  BackgroundColor white
  BorderColor black
  DiamondBackgroundColor white
  FontSize 11
}
skinparam ArrowColor black

title Activity Diagram — Đăng ký tài khoản khách hàng (FCAR)

|Khách hàng|
start
:Mở trang đăng ký tài khoản;
:Nhập họ tên, SĐT, email, mật khẩu, xác nhận mật khẩu;
:Gửi form đăng ký;

|Hệ thống FCAR|
:Validate dữ liệu bắt buộc và định dạng;
if (Dữ liệu hợp lệ?) then ([Không])
  |Khách hàng|
  :Hiển thị lỗi validation trên form;
  stop
else ([Có])
endif

|Hệ thống FCAR|
if (Mật khẩu đạt chính sách?) then ([Không])
  |Khách hàng|
  :Hiển thị lỗi chính sách mật khẩu;
  stop
else ([Có])
endif

|Hệ thống FCAR|
if (Mật khẩu xác nhận khớp?) then ([Không])
  |Khách hàng|
  :Hiển thị lỗi không khớp mật khẩu;
  stop
else ([Có])
endif

|Hệ thống FCAR|
if (Email hoặc SĐT đã tồn tại?) then ([Có])
  |Khách hàng|
  :Hiển thị lỗi trùng thông tin;
  stop
else ([Không])
endif

|Hệ thống FCAR|
:Tạo tài khoản CUSTOMER mới;
:Mã hóa mật khẩu và lưu CSDL;

|Khách hàng|
:Nhận thông báo đăng ký thành công;
:Chuyển tới trang đăng nhập;
stop

@enduml
