@startuml FCAR-dang-nhap-tai-khoan
' Ký hiệu theo mẫu giảng viên: swimlane, start/stop, nhánh [guard], fork/join

skinparam backgroundColor white
skinparam activity {
  BackgroundColor white
  BorderColor black
  DiamondBackgroundColor white
  FontSize 11
}
skinparam ArrowColor black

title Activity Diagram — Đăng nhập tài khoản khách hàng (FCAR)

|Khách hàng|
start
:Mở trang đăng nhập;

if (Chọn phương thức?) then ([Form Email/Mat khau])
  :Nhập email và mật khẩu;
  :Gửi yêu cầu đăng nhập;
  |Hệ thống FCAR|
  :Xác thực thông tin đăng nhập;
  if (Đúng thông tin?) then ([Không])
    |Khách hàng|
    :Hiển thị lỗi đăng nhập;
    stop
  else ([Có])
  endif
elseif ([Google OAuth2])
  :Bấm Dang nhap bang Google;
  |Google OAuth2|
  :Xác thực tài khoản Google;
  |Hệ thống FCAR|
  if (Xác thực Google thành công?) then ([Không])
    |Khách hàng|
    :Hiển thị lỗi đăng nhập Google;
    stop
  else ([Có])
    :Tạo/Cập nhật người dùng theo Google profile;
  endif
else ([OTP so dien thoai])
  :Nhập số điện thoại;
  |Hệ thống FCAR|
  :Gửi OTP đăng nhập;
  |Khách hàng|
  :Nhập mã OTP;
  |Hệ thống FCAR|
  :Xác thực OTP;
  if (OTP hợp lệ?) then ([Không])
    |Khách hàng|
    :Hiển thị lỗi OTP;
    stop
  else ([Có])
  endif
endif

|Hệ thống FCAR|
fork
  :Tạo phiên đăng nhập (session);
fork again
  :Xác định trang đích sau đăng nhập;
end fork

|Khách hàng|
:Được chuyển vào trang hệ thống;
stop

@enduml
